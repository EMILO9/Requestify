{
  "compilerOptions": {
    "target": "ES6", // ECMAScript target version
    "module": "commonjs", // Module code generation
    "declaration": true, // Generate .d.ts files
    "declarationDir": "./dist/types", // Output for declaration files
    "outDir": "./dist", // Output directory for compiled JS files
    "rootDir": "./", // Root directory that includes both main.ts and the "t" folder
    "strict": true, // Enable all strict type-checking options
    "esModuleInterop": true, // Ensures proper interop with ES modules
    "skipLibCheck": true, // Skip type checking of declaration files
    "forceConsistentCasingInFileNames": true // Enforce consistent casing for file imports
  },
  "include": ["main.ts", "t/**/*"], // Include both main.ts and all files under "t"
  "exclude": ["node_modules"] // Exclude node_modules
}
